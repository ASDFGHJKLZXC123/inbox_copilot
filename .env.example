# Auth.js v5 — required (was NEXTAUTH_SECRET in v4)
AUTH_SECRET=replace-me
AUTH_URL=http://localhost:3000

# Google OAuth (gmail.readonly scope)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Entra ID (Mail.Read scope)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# AI providers (at least one required for AI features)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Optional — enables Claude-backed copilot. Falls back to Gemini, then heuristics.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Webhook push (optional — enables real-time inbox updates)
GOOGLE_PUBSUB_TOPIC=
GOOGLE_PUSH_ENDPOINT=http://localhost:3000/api/webhooks/google
MICROSOFT_WEBHOOK_URL=http://localhost:3000/api/webhooks/microsoft

# Data directory (optional — defaults to .data/ in project root)
# DATA_DIR=/var/data/inbox

# OAuth token encryption at rest (recommended).
# 32 random bytes, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# If unset, tokens are written plaintext (legacy MVP behavior).
# If you change the value, existing encrypted tokens become unreadable —
# users will need to reconnect their inbox.
ENCRYPTION_KEY=

# Logging (optional). Defaults: debug in dev, info in production.
LOG_LEVEL=

# Postgres (optional — falls back to .data/inbox.json when unset). See docs/postgres-runbook.md.
DATABASE_URL=

# Reminder email delivery (optional — reminders are stored but not delivered without these).
RESEND_API_KEY=
REMINDER_FROM_ADDRESS=

# Optional Pub/Sub OIDC audience (defaults to GOOGLE_PUSH_ENDPOINT). Set when you want a different
# audience claim from the Pub/Sub push endpoint URL.
GOOGLE_PUBSUB_AUDIENCE=

# OpenTelemetry (optional, deferred — see Phase 8 of REMEDIATION_PLAN.md)
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_SERVICE_NAME=ai-inbox-copilot
